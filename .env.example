# -------------------------
# Goatify IA - Environment Example
# Copia esto en Cloud Run > Variables & Secrets. Nunca subas .env real a GitHub.
# -------------------------
NODE_ENV=production
APP_URL=https://TU-SERVICIO.run.app
FRONTEND_URL=https://TU-SERVICIO.run.app
ALLOWED_ORIGINS=https://TU-DOMINIO.com,https://www.TU-DOMINIO.com,https://TU-SERVICIO.run.app

# Server/runtime
PORT=8080
API_JSON_LIMIT=10mb
API_IMAGE_JSON_LIMIT=25mb
API_DOCS_JSON_LIMIT=50mb
API_MEDIA_JSON_LIMIT=100mb
EXPOSE_RUNTIME_HEALTH=false
EXPOSE_DEBUG_TTS=false

# AI keys. El backend prioriza GEMINI_API_KEY, luego API_KEY, luego GOOGLE_API_KEY.
GEMINI_API_KEY=
API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=
IMAGEN_MODEL=imagen-4.0-generate-001
CHAT_FAST_MODEL=gemini-3.1-flash-lite-preview
CHAT_STANDARD_MODEL=gemini-3-flash-preview
# Gemini Pro solo se usará si el usuario tiene plan premium y subscriptionStatus=active.
CHAT_PRO_MODEL=gemini-2.5-pro

# Firebase Admin
FIREBASE_PROJECT_ID=goatify-app-ia
FIREBASE_STORAGE_BUCKET=goatify-app-ia.firebasestorage.app
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# OAuth Mail / Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VITE_VAPID_PUBLIC_KEY=

# Email encryption. Usa una frase larga única. No la cambies luego o no podrás descifrar cuentas guardadas.
EMAIL_ENCRYPTION_KEY=

# Background jobs / costo
ENABLE_MAIL_POLLING=false
MAIL_POLL_INTERVAL_MS=900000
ENABLE_NEWS_AUTOMATION=false
ALLOW_UNAUTHENTICATED_LIVE_PROXY=false

# Reminder worker: crea notificaciones internas/push para posts sociales y reuniones próximas.
ENABLE_REMINDER_WORKER=true
REMINDER_WORKER_INTERVAL_MS=60000
REMINDER_LOOKAHEAD_MINUTES=90

# Seguridad V17
RATE_LIMIT_API_PER_MINUTE=240
RATE_LIMIT_AI_PER_MINUTE=40
RATE_LIMIT_PUBLIC_EMAIL_PER_MINUTE=20
# Opcional. Si lo configuras, las acciones públicas/email deben enviar x-goatify-public-token = HMAC_SHA256(secret, ownerId/formId/projectId/agentId/path).
# No lo actives hasta agregar el token en los formularios públicos y páginas externas.
PUBLIC_ACTION_SECRET=
