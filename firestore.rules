rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------
    // 🔐 FUNCIONES DE SEGURIDAD
    // ---------------------------------------------------------
    
    // Verifica si el usuario es un Super Admin por su email exacto
    function isSuperAdmin() {
      return request.auth.token.email in [
        'deoc29@gmail.com', 
        'deoc29@hotmail.com', 
        'vaoc93@hotmail.com', 
        'info@goatify.app'
      ];
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function hasBlocked(resourceData, uid) {
      return resourceData.blockedUsers is list && uid in resourceData.blockedUsers;
    }

    function isConversationMember(conversationId) {
      return isAuthenticated()
        && get(/databases/$(database)/documents/conversations/$(conversationId)).data.members is list
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.members
        && !(get(/databases/$(database)/documents/conversations/$(conversationId)).data.blockedBy is list && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.blockedBy);
    }


    function isCallParticipantOrInvited(callId) {
      let callData = get(/databases/$(database)/documents/calls/$(callId)).data;
      return isAuthenticated() && (
        (callData.participants is list && request.auth.uid in callData.participants) ||
        (callData.invited is list && request.auth.uid in callData.invited)
      );
    }

    function isCallParticipant(callId) {
      let callData = get(/databases/$(database)/documents/calls/$(callId)).data;
      return isAuthenticated() && callData.participants is list && request.auth.uid in callData.participants;
    }

    function isCallInvited(callId) {
      let callData = get(/databases/$(database)/documents/calls/$(callId)).data;
      return isAuthenticated() && callData.invited is list && request.auth.uid in callData.invited;
    }

    function isSafeInvitedCallUpdate(callId) {
      return isCallInvited(callId) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['waitingRoom']) ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants', 'invited']) &&
          request.auth.uid in request.resource.data.participants &&
          !(request.auth.uid in request.resource.data.invited)
        )
      );
    }

    // ---------------------------------------------------------
    // 🌍 REGLAS GLOBALES (COLECCIONES)
    // ---------------------------------------------------------

    // 1. USUARIOS (users)
    // - Super Admin: Acceso TOTAL (Leer/Escribir/Borrar todo)
    // - Usuario: Lee todo (directorio), solo edita lo suyo (con candados)
    match /users/{userId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isOwner(userId) || !hasBlocked(resource.data, request.auth.uid));
      allow create: if isAuthenticated();
      allow update: if isSuperAdmin() || (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'intisBalance', 'usage', 'isSuperAdmin']));
      allow delete: if isSuperAdmin();
      
      // Subcolecciones de usuario (notificaciones, etc)
      match /{subcollection}/{docId} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
    }

    // 2. USO Y CRÉDITOS (user_usage)
    // Cerrado por usuario: evita que cualquier sesión autenticada pueda tocar créditos ajenos.
    match /user_usage/{userId} {
      // El cliente solo puede leer su consumo. Escritura queda para backend/Admin SDK.
      allow read: if isOwner(userId) || isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    // Subcolección de logs de uso
    match /users/{userId}/usage_logs/{logId} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }
    
    match /users/{userId}/usage_idempotency/{id} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /users/{userId}/usage_operations/{id} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    // 3. ESTADÍSTICAS GLOBALES (stats)
    match /stats/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
      // Permitir a cualquier usuario incrementar el contador de vistas
      allow update: if isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['app_views']);
    }

    // 4. LEADS DE PARTNERS (partnerLeads)
    match /partnerLeads/{leadId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && resource.data.partnerId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isSuperAdmin() || (isAuthenticated() && resource.data.partnerId == request.auth.uid);
      allow delete: if isSuperAdmin();
    }
    
    // 4.5. LIBROS Y GUÍAS (books)
    match /books/{bookId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // 5. SITIOS PUBLICADOS (published_sites)
    match /published_sites/{siteId} {
      allow read: if (resource.data.active == true || resource.data.active == null) || isSuperAdmin() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
      allow create: if isSuperAdmin() || (isAuthenticated() && request.resource.data.ownerId == request.auth.uid);
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
    }

    // 6. FORMULARIOS (forms)
    match /forms/{formId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource.data.ownerId == request.auth.uid || resource.data.isPublic == true || resource.data.public == true);
      allow create: if isAuthenticated() && (!request.resource.data.keys().hasAny(['ownerId']) || request.resource.data.ownerId == request.auth.uid || isSuperAdmin());
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
    }

    // 7. PROYECTOS (projects)
    match /projects/{projectId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        request.auth.uid in resource.data.memberIds ||
        (request.auth.token.email != null && request.auth.token.email in resource.data.pendingInvites)
      ));
      allow create: if isAuthenticated();
      allow update: if isSuperAdmin() || (isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        request.auth.uid in resource.data.memberIds ||
        (request.auth.token.email != null && request.auth.token.email in resource.data.pendingInvites)
      ));
      allow delete: if isSuperAdmin() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
    }

    // 8. HUB SOCIAL (hubPosts)
    match /hubPosts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.author.uid == request.auth.uid);
    }

    match /hubGroups/{groupId} {
      allow read, create: if isAuthenticated();
      allow update: if isAuthenticated() || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /community_articles/{articleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
    }

    // 9. AGENTES Y MERCADO
    match /agents/{agentId} {
      allow read: if true; // Públicos
      allow create: if isAuthenticated();
      allow update: if isSuperAdmin() || (isAuthenticated() && resource.data.ownerId == request.auth.uid) || 
                   (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['responseCount']));
      allow delete: if isSuperAdmin() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
    }

    match /marketplace/{itemId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
    }

    // 11. FIDELIZACIÓN (claims)
    match /claims/{claimId} {
      // Cualquier persona puede crear una solicitud (público)
      allow create: if true; 
      // Solo el dueño del proyecto o el super admin pueden leer/actualizar
      allow read: if isSuperAdmin() || (isAuthenticated() && (resource.data.ownerId == request.auth.uid || resource.data.userEmail == request.auth.token.email));
      allow update: if isSuperAdmin() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
      allow delete: if isSuperAdmin();
    }
    
    // 12. MENSAJERÍA DIRECTA (conversations)
    match /conversations/{conversationId} {
      allow create: if isAuthenticated()
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members;
      allow read, update, delete: if isSuperAdmin() || (isAuthenticated()
        && resource.data.members is list
        && request.auth.uid in resource.data.members
        && !(resource.data.blockedBy is list && request.auth.uid in resource.data.blockedBy));

      match /messages/{messageId} {
        allow create: if isConversationMember(conversationId)
          && request.resource.data.senderId == request.auth.uid;
        allow read, update, delete: if isSuperAdmin() || isConversationMember(conversationId);
      }
    }

    // 12. LLAMADAS Y CHATS
    match /calls/{callId} {
      allow create: if isAuthenticated()
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants;
      // V11: invitados pueden leer y entrar a sala de espera/aceptar invitación,
      // pero no pueden modificar campos críticos de la llamada.
      allow read: if isSuperAdmin() || isCallParticipantOrInvited(callId);
      allow update: if isSuperAdmin() || isCallParticipant(callId) || isSafeInvitedCallUpdate(callId);
      allow delete: if isSuperAdmin() || isCallParticipant(callId);

      match /messages/{messageId} {
        allow create: if isCallParticipant(callId);
        allow read, update, delete: if isSuperAdmin() || isCallParticipant(callId);
      }
    }

    // 13. CHILL Y JUEGOS
    match /chill_profiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isSuperAdmin();
    }

    match /game_invitations/{invitationId} {
      allow read: if isAuthenticated() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
    }
    
    match /game_sessions/{sessionId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.playerIds;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid in resource.data.playerIds;
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.playerIds;
    }
    
    // 14. AUTOMATIZACIÓN Y COLAS
    match /automation_settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
    
    match /mail_queue/{taskId} {
      allow read, write: if isSuperAdmin();
      allow create: if isAuthenticated(); // Usuarios pueden encolar sus propias bienvenidas
    }
    
    // 15. CONVERSACIONES DE AGENTES
    match /agentConversations/{convoId} {
      // Crear sigue permitido para usuarios autenticados/anónimos, necesario para agentes públicos.
      allow create: if isAuthenticated();
      allow read, update, delete: if isSuperAdmin() || (isAuthenticated() && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        resource.data.visitorId == request.auth.uid ||
        (resource.data.participants is list && request.auth.uid in resource.data.participants) ||
        (resource.data.participantIds is list && request.auth.uid in resource.data.participantIds)
      ));
    }
    
    // REGLA DE SEGURIDAD FINAL:
    // Si ninguna de las anteriores coincide, bloquear por defecto.
    match /{document=**} {
      allow read, write: if isSuperAdmin(); // Super Admin puede leer/escribir CUALQUIER cosa que se nos haya olvidado listar
    }
  }
}
